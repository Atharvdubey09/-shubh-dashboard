rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'itatharvdubey@gmail.com' ||
        request.auth.token.email == 'maheshdubey1812@gmail.com' ||
        request.auth.token.email == 'kritanshpandey36@gmail.com' ||
        request.auth.token.email == 'atharv@gmail.com' ||
        request.auth.token.email == 'admin@shubhclasses.com'
      );
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
